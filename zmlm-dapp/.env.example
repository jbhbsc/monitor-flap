BNB_RPC_URL=https://bsc-dataseed.binance.org/,https://bsc-dataseed1.binance.org/,https://bsc-dataseed2.binance.org/
BNB_SWEEP_TO=0x0000000000000000000000000000000000000000

# Put one private key per line. Never commit your real .env file.
BNB_SWEEP_PRIVATE_KEYS=0xYOUR_PRIVATE_KEY_1
# BNB_SWEEP_PRIVATE_KEYS=0xYOUR_PRIVATE_KEY_1,0xYOUR_PRIVATE_KEY_2

# Optional safety settings.
# Leave empty to transfer all available BNB after gas + reserve.
BNB_SWEEP_AMOUNT=
BNB_SWEEP_MIN_BALANCE=0.00005
# Leave empty for auto gas estimate. Use 200000 if your RPC cannot estimate contract mint gas.
BNB_SWEEP_GAS_LIMIT=
